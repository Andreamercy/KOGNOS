# ── LLM Backend ──────────────────────────────────────────────────────────────
# Set to "anthropic" or "ollama"
LLM_BACKEND=anthropic

# Anthropic Claude (required if LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (required if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Qdrant Vector Store ───────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kognos_knowledge

# ── Kafka Streaming ───────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_FLOWS=ebpf-flows
KAFKA_TOPIC_ALERTS=kognos-alerts

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBECONFIG=~/.kube/config

# ── Demo / Dev Mode ───────────────────────────────────────────────────────────
# Set to "true" to use synthetic data instead of a real k8s cluster
KOGNOS_DEMO_MODE=true

# ── GNN Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/graphsage_v1.pt
ANOMALY_THRESHOLD=0.75
AUTO_HEAL_THRESHOLD=0.9
DRY_RUN=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
